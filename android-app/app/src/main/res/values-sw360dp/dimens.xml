<?xml version="1.0" encoding="utf-8"?>
<!-- 小屏幕设备（< 5英寸）优化 -->
<resources>
    <!-- 间距 -->
    <dimen name="spacing_tiny">3dp</dimen>
    <dimen name="spacing_small">6dp</dimen>
    <dimen name="spacing_medium">10dp</dimen>
    <dimen name="spacing_large">12dp</dimen>
    <dimen name="spacing_xlarge">16dp</dimen>
    
    <!-- 屏幕边距 -->
    <dimen name="screen_padding_horizontal">12dp</dimen>
    <dimen name="screen_padding_vertical">12dp</dimen>
    <dimen name="screen_padding_bottom">20dp</dimen>
    
    <!-- 卡片样式 -->
    <dimen name="card_radius">10dp</dimen>
    <dimen name="card_radius_large">14dp</dimen>
    <dimen name="card_elevation">2dp</dimen>
    <dimen name="card_elevation_medium">3dp</dimen>
    
    <!-- 卡片内边距 -->
    <dimen name="card_padding">12dp</dimen>
    <dimen name="card_padding_large">16dp</dimen>
    <dimen name="item_padding">10dp</dimen>
    
    <!-- 字体大小 -->
    <dimen name="text_size_caption">11sp</dimen>
    <dimen name="text_size_small">13sp</dimen>
    <dimen name="text_size_normal">15sp</dimen>
    <dimen name="text_size_button">15sp</dimen>
    <dimen name="text_size_title">16sp</dimen>
    <dimen name="text_size_large">18sp</dimen>
    
    <!-- 图标尺寸 -->
    <dimen name="icon_size">40dp</dimen>
    <dimen name="icon_padding">6dp</dimen>
    <dimen name="status_icon_size">28dp</dimen>
    
    <!-- 触摸目标最小尺寸 -->
    <dimen name="touch_target_min">48dp</dimen>
    
    <!-- 按钮高度 -->
    <dimen name="button_height">52dp</dimen>
    <dimen name="button_height_large">60dp</dimen>
</resources>
